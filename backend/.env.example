# Database (PostgreSQL — Neon cloud or local)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/maintainiq?sslmode=require"

# App
PORT=4000
NODE_ENV=development

# Auth (set in later step)
JWT_SECRET="change-me"
JWT_EXPIRES_IN="7d"

# AI Issue Triage — OpenAI-compatible chat-completions endpoint.
# Works with Grok (default), OpenRouter, OR Google Gemini's OpenAI-compat layer:
#   GROK_API_KEY=<your Gemini key from https://aistudio.google.com/apikey>
#   GROK_API_URL="https://generativelanguage.googleapis.com/v1beta/openai"
#   GROK_MODEL="gemini-2.0-flash"
GROK_API_KEY=""
GROK_API_URL="https://api.x.ai/v1"
GROK_MODEL="grok-2-latest"

# Cloudinary (evidence upload — set in later step)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Email (SMTP) — optional; notifications no-op if unset.
# Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USER=<your gmail>,
# SMTP_PASS=<16-char App Password from Google Account > Security > App Passwords>
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="MaintainIQ <no-reply@maintainiq.app>"

# Google OAuth (social sign-in) — from Google Cloud Console > APIs & Services >
# Credentials > OAuth client ID (Web application). Authorized redirect URI must
# be exactly {API_URL}/auth/google/callback.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# This API's own public base URL (used to build the Google OAuth callback URL)
API_URL="http://localhost:4000/api"

# Frontend base URL (used for password-reset links and the OAuth hand-off redirect)
FRONTEND_URL="http://localhost:3000"

# Public asset page base URL (used inside generated QR codes)
PUBLIC_APP_URL="http://localhost:3000"
